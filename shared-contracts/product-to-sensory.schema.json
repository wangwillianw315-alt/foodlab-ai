{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://foodlab.local/schemas/product-to-sensory.schema.json",
  "title":"Product Development to Sensory Transfer 1.0.0",
  "allOf":[
    {"$ref":"foodlab-envelope.schema.json"},
    {
      "type":"object",
      "properties":{
        "transfer_type":{"const":"PRODUCT_TO_SENSORY"},"source_module":{"const":"PRODUCT_DEVELOPMENT"},"target_module":{"const":"SENSORY"},"source_record_id":{"type":"string","pattern":"^PD-[A-Fa-f0-9]{8,}$"},
        "payload":{
          "type":"object",
          "required":["product_project_id","product_id","product_name","product_category","samples","suggested_test_design"],
          "properties":{
            "product_project_id":{"type":"string","pattern":"^PD-[A-Fa-f0-9]{8,}$"},"product_id":{"type":"string","pattern":"^PR-[A-Fa-f0-9]{8,}$"},
            "product_name":{"type":"string","minLength":1},"product_category":{"type":"string","minLength":1},
            "project_objective":{"type":"string"},"target_consumer":{"type":"string"},
            "samples":{"type":"array","minItems":1,"maxItems":4,"items":{"type":"object","required":["formula_version_id","formula_version_name","sample_name","allergens","ingredient_summary","demo_only"],"properties":{"formula_version_id":{"type":"string","pattern":"^FV-[A-Fa-f0-9]{8,}$"},"formula_version_name":{"type":"string"},"sample_name":{"type":"string","minLength":1},"allergens":{"type":"array","items":{"type":"string"}},"ingredient_summary":{"type":"array","items":{"type":"string"}},"demo_only":{"type":"boolean"},"cost_summary":{"type":["number","null"]}},"additionalProperties":true}},
            "suggested_test_design":{"type":"object","required":["test_types","attributes","notes"],"properties":{"test_types":{"type":"array","items":{"type":"string"}},"attributes":{"type":"array","items":{"type":"string"}},"notes":{"type":"string"}},"additionalProperties":true}
          },"additionalProperties":true
        }
      }
    }
  ]
}
